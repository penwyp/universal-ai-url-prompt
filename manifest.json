{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "0.0.1",
  "default_locale": "en",
  "description": "__MSG_appDesc__",
  "author": "penwyp",
  "homepage_url": "https://github.com/penwyp/universal-ai-url-prompt",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "webNavigation",
    "storage"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://ying.baichuan-ai.com/*",
        "https://chat.baichuan-ai.com/*",
        "https://baichuan-ai.com/*",
        "https://www.baichuan-ai.com/*",
        "https://chatglm.cn/*",
        "https://chatgpt.com/*",
        "https://www.chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://chat.deepseek.com/*",
        "https://www.deepseek.com/*",
        "https://deepseek.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://duck.ai/*",
        "https://www.duck.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://www.grok.com/*",
        "https://huggingface.co/chat*",
        "https://www.huggingface.co/chat*",
        "https://hf.co/chat*",
        "https://kimi.moonshot.cn/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.mistral.ai/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://poe.com/*",
        "https://www.poe.com/*",
        "https://chat.qwen.ai/*",
        "https://yuanbao.tencent.com/*",
        "https://yiyan.baidu.com/*",
        "https://wenxiaoyan.baidu.com/*",
        "https://chat.baidu.com/*",
        "https://z.ai/*",
        "https://www.z.ai/*",
        "https://chat.z.ai/*"
      ],
      "js": [
        "platforms/_registry.js",
        "platforms/baichuan.js",
        "platforms/chatglm.js",
        "platforms/chatgpt.js",
        "platforms/claude.js",
        "platforms/deepseek.js",
        "platforms/doubao.js",
        "platforms/duckduckgo-ai.js",
        "platforms/gemini.js",
        "platforms/grok.js",
        "platforms/huggingchat.js",
        "platforms/kimi.js",
        "platforms/meta-ai.js",
        "platforms/microsoft-copilot.js",
        "platforms/mistral-le-chat.js",
        "platforms/perplexity.js",
        "platforms/poe.js",
        "platforms/qwen.js",
        "platforms/tencent-yuanbao.js",
        "platforms/wenxiaoyan.js",
        "platforms/z-ai.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
